LLM_PROVIDER=mock

# SiliconFlow / OpenAI-compatible endpoint
SILICONFLOW_API_KEY=
LLM_MODEL=deepseek-ai/DeepSeek-V3
LLM_BASE_URL=https://api.siliconflow.cn/v1

# OpenAI
OPENAI_API_KEY=

# Notifications. Default keeps a JSON audit outbox only.
NOTIFICATION_CHANNELS=json

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_BASE_URL=https://api.sendgrid.com

# Feishu custom bot
FEISHU_WEBHOOK_URL=

# HR approval gate. Candidate-facing real sends require approved status.
HR_APPROVAL_STATUS=pending
HR_APPROVAL_FILE=
HR_APPROVED_BY=
HR_APPROVAL_NOTES=

# LangGraph checkpointing
CHECKPOINT_DB=data/checkpoints.sqlite
THREAD_ID=recruitment-demo
